{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uplexos.local/schemas/project-state.schema.json",
  "title": "UplexOS Project State",
  "type": "object",
  "required": ["schema_version", "project_id", "status", "updated_at"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "project_id": { "type": "string", "minLength": 1 },
    "tier": { "enum": ["mvp", "startup", "enterprise", "undefined"] },
    "phase": { "type": "string" },
    "status": { "enum": ["planned", "in_progress", "blocked", "completed", "archived"] },
    "active_task_id": { "type": ["string", "null"] },
    "active_skill": { "type": ["string", "null"] },
    "last_verified_commit": { "type": ["string", "null"] },
    "quality_gate": { "enum": ["pending", "passed", "failed", "not_applicable"] },
    "security_gate": { "enum": ["pending", "passed", "failed", "not_applicable"] },
    "blocked_by": { "type": "array", "items": { "type": "string" } },
    "approvals": { "type": "array", "items": { "type": "string" } },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
