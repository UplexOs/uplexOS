    "agencia": { "prompts": ["4.1-hero-agencia-statement", "4.2-site-agencia-completo", "4.3-showreel-hero"], "default": "4.2-site-agencia-completo" },
    "lancamento": { "prompts": ["3.1-hero-lancamento-countdown", "3.2-pagina-drop", "3.3-waitlist-coming-soon"], "default": "3.2-pagina-drop" },
    "luxo": { "prompts": ["8.1-hero-fashion-editorial", "8.2-landing-marca-luxo", "8.3-joia-relogio"], "default": "8.2-landing-marca-luxo" },
    "evento": { "prompts": ["7.1-hero-evento", "7.2-landing-evento-completa", "7.4-ingressos-tiers"], "default": "7.2-landing-evento-completa" }
  }
}