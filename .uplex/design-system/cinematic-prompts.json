{
  "version": "1.0.0",
  "dna": {
    "background": "near-black (#0a0a0b) ou warm canvas (#FAFAF8)",
    "lighting": "luz dramática, key light, soft falloff",
    "depth": "parallax, sticky scroll, 3D perspective",
    "typography": "serif display gigante + sans corpo limpa",
    "texture": "film grain, vignette, grid dots",
    "quality": "nível Awwwards Site of the Day"
  },
  "mapping": {
    "saas": { "prompts": ["1.1-hero-site-of-the-day", "1.2-landing-scroll-driven", "1.4-dashboard-reveal", "1.5-pricing-cta"], "default": "1.2-landing-scroll-driven" },
    "app_mobile": { "prompts": ["6.1-hero-app-mockup", "6.2-landing-app-completa", "6.4-feature-scroll"], "default": "6.2-landing-app-completa" },
    "portfolio": { "prompts": ["2.1-portfolio-editorial-hero", "2.2-portfolio-scroll", "2.3-marca-pessoal-kinetic"], "default": "2.2-portfolio-scroll" },
